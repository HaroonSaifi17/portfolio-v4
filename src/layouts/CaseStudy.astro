---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.svelte';
import Footer from '../components/Footer.svelte';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  slug?: string;
}

const { title, description, pubDate, updatedDate, heroImage, slug } =
  Astro.props;
const transitionId =
  slug ?? `case-study-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title={`${title} — Case Study`} description={description}>
  <Navbar client:load />

  <article
    class="max-w-3xl mx-auto px-6 py-20"
    transition:name={`case-study-card-${transitionId}`}
  >
    <header class="mb-16 space-y-6">
      <a
        href="/#work"
        class="post-back inline-block font-black uppercase tracking-widest text-sm border-b-4 border-foreground nav-link-hover"
      >
        &larr; Back to Work
      </a>

      <h1
        class="post-title text-4xl md:text-6xl font-black uppercase tracking-tighter leading-tight"
        transition:name={`case-study-title-${transitionId}`}
      >
        {title}
      </h1>

      <div class="post-meta flex flex-wrap gap-4 items-center">
        <span
          class="font-black uppercase tracking-widest bg-foreground text-background px-3 py-1 text-sm"
          transition:name={`case-study-date-${transitionId}`}
        >
          {formatDate(pubDate)}
        </span>
        {
          updatedDate && (
            <span class="font-bold text-muted-foreground text-sm uppercase tracking-widest">
              Updated {formatDate(updatedDate)}
            </span>
          )
        }
      </div>

      {
        heroImage && (
          <img
            src={heroImage}
            alt={title}
            class="post-hero w-full border-4 border-foreground shadow-[var(--shadow-lg)]"
            transition:name={`case-study-hero-${transitionId}`}
          />
        )
      }
    </header>

    <div class="post-content prose prose-lg max-w-none">
      <slot />
    </div>
  </article>

  <Footer client:visible />
</Layout>
