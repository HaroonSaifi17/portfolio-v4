---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.svelte';
import Footer from '../components/Footer.svelte';
import BackToTop from '../components/BackToTop.svelte';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  slug?: string;
  tags?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  slug,
  tags = [],
} = Astro.props;
const transitionId =
  slug ?? `blog-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const currentIndex = posts.findIndex((post) => post.id === slug);
const prevPost = currentIndex >= 0 ? posts[currentIndex + 1] : undefined;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title={`${title} | Mohd Haroon Blog`}
  description={description}
  image={heroImage ?? '/images/preview.png'}
  imageAlt={title}
  type="article"
  schemaType="BlogPosting"
  publishDate={pubDate}
  modifiedDate={updatedDate ?? pubDate}
  section="Blog"
  tags={tags}
  keywords={['software engineering blog', 'web development', 'typescript']}
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Blog', item: '/blog' },
    { name: title, item: `/blog/${slug ?? ''}` },
  ]}
>
  <Navbar client:load />

  <article
    id="top"
    class="max-w-3xl mx-auto px-6 py-20"
    transition:name={`blog-card-${transitionId}`}
  >
    <header class="mb-16 space-y-6">
      <a
        href="/blog"
        class="post-back inline-block font-black uppercase tracking-widest text-sm border-b-4 border-foreground nav-link-hover"
      >
        &larr; All Posts
      </a>

      <h1
        class="post-title text-4xl md:text-6xl font-black uppercase tracking-tighter leading-tight"
        transition:name={`blog-title-${transitionId}`}
      >
        {title}
      </h1>

      <div class="post-meta flex flex-wrap gap-4 items-center">
        <span
          class="font-black uppercase tracking-widest bg-foreground text-background px-3 py-1 text-sm"
          transition:name={`blog-date-${transitionId}`}
        >
          {formatDate(pubDate)}
        </span>
        {
          updatedDate && (
            <span class="font-bold text-muted-foreground text-sm uppercase tracking-widest">
              Updated {formatDate(updatedDate)}
            </span>
          )
        }
        <a
          href={`https://github.com/HaroonSaifi17/portfolio-v4/edit/master/src/content/blog/${slug}.mdx`}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-auto flex items-center gap-1.5 font-bold text-sm uppercase tracking-widest hover:text-primary transition-colors"
          title="Suggest an edit on GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg>
        </a>
      </div>

      {
        heroImage && (
          <img
            src={heroImage}
            alt={title}
            class="post-hero w-full border-4 border-foreground shadow-[var(--shadow-lg)]"
            transition:name={`blog-hero-${transitionId}`}
          />
        )
      }
    </header>

    <div class="post-content prose prose-lg max-w-none">
      <slot />
    </div>

    <nav class="post-pagination mt-16 border-t-4 border-foreground pt-8">
      {prevPost ? (
        <a
          href={`/blog/${prevPost.id}`}
          class="post-nav-link"
          data-astro-prefetch
        >
          <span class="post-nav-label">Previous</span>
          <span class="post-nav-title">{prevPost.data.title}</span>
        </a>
      ) : (
        <span class="post-nav-link post-nav-link--disabled" aria-hidden="true">
          <span class="post-nav-label">Previous</span>
          <span class="post-nav-title">—</span>
        </span>
      )}

      {nextPost ? (
        <a
          href={`/blog/${nextPost.id}`}
          class="post-nav-link post-nav-link--next"
          data-astro-prefetch
        >
          <span class="post-nav-label">Next</span>
          <span class="post-nav-title">{nextPost.data.title}</span>
        </a>
      ) : (
        <span class="post-nav-link post-nav-link--disabled" aria-hidden="true">
          <span class="post-nav-label">Next</span>
          <span class="post-nav-title">—</span>
        </span>
      )}
    </nav>
  </article>

  <BackToTop client:only="svelte" />

  <Footer />
</Layout>

<style>
  .post-pagination {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .post-nav-link {
    border: 4px solid var(--border);
    background: var(--card);
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .post-nav-link:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px 0px rgba(0, 0, 0, 1);
    border-color: var(--primary);
  }

  .post-nav-link--next {
    text-align: right;
  }

  .post-nav-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .post-nav-title {
    font-size: 1.05rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .post-nav-link--disabled {
    opacity: 0.5;
    box-shadow: none;
  }

  .back-to-top {
    position: fixed;
    right: 20px;
    bottom: 24px;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--border);
    background: var(--card);
    font-size: 20px;
    font-weight: 900;
    box-shadow: var(--shadow-sm);
    z-index: 40;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .back-to-top:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px 0px rgba(0, 0, 0, 1);
    border-color: var(--primary);
  }

  @media (max-width: 640px) {
    .post-pagination {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-nav-link {
      transition: none;
    }
  }
</style>
