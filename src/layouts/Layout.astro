---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  schemaType?: 'Article' | 'BlogPosting' | 'TechArticle';
  publishDate?: Date | string;
  modifiedDate?: Date | string;
  noindex?: boolean;
  section?: string;
  tags?: string[];
  keywords?: string[];
  breadcrumbs?: Array<{ name: string; item: string }>;
}

const {
  title = 'Mohd Haroon — Full Stack Developer',
  description = 'Self-taught full stack developer building production-grade web applications. React, Node.js, TypeScript, Web3.',
  image = '/images/preview.png',
  imageAlt = 'Mohd Haroon portfolio preview',
  canonicalURL,
  type = 'website',
  schemaType = 'Article',
  publishDate,
  modifiedDate,
  noindex = false,
  section,
  tags = [],
  keywords = [],
  breadcrumbs = [],
} = Astro.props;

const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(canonicalURL ?? Astro.url.pathname, site).toString();
const imageUrl = new URL(image, site).toString();
const robots = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
const publishedISO = publishDate
  ? new Date(publishDate).toISOString()
  : undefined;
const modifiedISO = modifiedDate
  ? new Date(modifiedDate).toISOString()
  : publishedISO;
const allKeywords = Array.from(
  new Set([
    'Mohd Haroon',
    'full stack developer',
    'web developer portfolio',
    'TypeScript developer',
    'React developer',
    'Astro developer',
    ...keywords,
    ...tags,
  ]),
);

const personSchemaId = new URL('/#person', site).toString();
const websiteSchemaId = new URL('/#website', site).toString();
const webpageSchemaId = `${canonical}#webpage`;
const personSchema = {
  '@type': 'Person',
  '@id': personSchemaId,
  name: 'Mohd Haroon',
  url: site.toString(),
  jobTitle: 'Full Stack Developer',
  sameAs: [
    'https://github.com/HaroonSaifi17',
    'https://linkedin.com/in/haroonsaifi17',
    'https://x.com/HaroonSaifi17_',
    'https://leetcode.com/u/HaroonSaifi17/',
  ],
};
const websiteSchema = {
  '@type': 'WebSite',
  '@id': websiteSchemaId,
  url: site.toString(),
  name: 'Mohd Haroon Portfolio',
  inLanguage: 'en-US',
  description:
    'Personal portfolio, case studies, and engineering articles by Mohd Haroon.',
  publisher: { '@id': personSchemaId },
};
const pageSchema =
  type === 'article'
    ? {
        '@type': schemaType,
        '@id': webpageSchemaId,
        mainEntityOfPage: canonical,
        headline: title,
        description,
        image: [imageUrl],
        datePublished: publishedISO,
        dateModified: modifiedISO ?? publishedISO,
        author: { '@id': personSchemaId },
        publisher: { '@id': personSchemaId },
        articleSection: section,
        keywords: allKeywords.join(', '),
        inLanguage: 'en-US',
        isPartOf: { '@id': websiteSchemaId },
      }
    : {
        '@type': 'WebPage',
        '@id': webpageSchemaId,
        url: canonical,
        name: title,
        description,
        image: imageUrl,
        inLanguage: 'en-US',
        isPartOf: { '@id': websiteSchemaId },
      };
const breadcrumbSchema =
  breadcrumbs.length > 0
    ? {
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((crumb, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: crumb.name,
          item: new URL(crumb.item, site).toString(),
        })),
      }
    : undefined;
const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    personSchema,
    websiteSchema,
    pageSchema,
    ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ],
};
const schemaJSON = JSON.stringify(schemaGraph).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Font cssVariable="--font-space-grotesk" preload />
    <Font cssVariable="--font-jetbrains-mono" preload />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content="Mohd Haroon" />
    <meta name="keywords" content={allKeywords.join(', ')} />
    <meta name="theme-color" content="#ff4d00" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Mohd Haroon Portfolio" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@HaroonSaifi17_" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta name="twitter:creator" content="@HaroonSaifi17_" />

    {
      publishedISO && (
        <meta property="article:published_time" content={publishedISO} />
      )
    }
    {
      modifiedISO && <meta property="article:modified_time" content={modifiedISO} />
    }
    {
      section && <meta property="article:section" content={section} />
    }
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <script is:inline type="application/ld+json" set:html={schemaJSON}></script>
    <title>{title}</title>
    <slot name="head" />
    <ClientRouter />
    <script is:inline>
      function applyTheme() {
        var theme = localStorage.getItem('theme');
        var palette = localStorage.getItem('palette');
        var isDark = theme === 'dark';
        var root = document.documentElement;
        root.classList.toggle('dark', isDark);
        if (palette) {
          root.setAttribute('data-theme', palette);
        } else {
          root.removeAttribute('data-theme');
        }
      }

      function setPalette(palette) {
        var root = document.documentElement;

        if (!palette || palette === 'default') {
          root.removeAttribute('data-theme');
          localStorage.removeItem('palette');
          return;
        }

        root.setAttribute('data-theme', palette);
        localStorage.setItem('palette', palette);
      }

      function scrollToHash() {
        var hash = window.location.hash;
        if (!hash) return;
        var el = document.querySelector(hash);
        if (!el) return;
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      applyTheme();
      window.addEventListener('load', scrollToHash);
      document.addEventListener('astro:after-swap', () => {
        applyTheme();
        requestAnimationFrame(scrollToHash);
      });

      document.addEventListener('click', function (e) {
        var target = e.target;
        if (!(target instanceof Element)) return;
        var seed = target.closest('[data-palette]');
        if (!seed) return;
        var palette = seed.getAttribute('data-palette');
        setPalette(palette);
      });
    </script>
  </head>
  <body class="selection:bg-primary selection:text-primary-foreground">
    <slot />
    <div
      id="cursor"
      aria-hidden="true"
      class="pointer-events-none fixed left-0 top-0 z-[9999] h-4 w-4 rounded-full border-2 border-foreground bg-background transition-transform duration-150 ease-out"
    ></div>
    <div
      id="cursor-ring"
      aria-hidden="true"
      class="pointer-events-none fixed left-0 top-0 z-[9998] h-10 w-10 rounded-full border-2 border-foreground/60 transition-transform duration-200 ease-out"
    ></div>
    <script is:inline>
      (function () {
        var cursor = document.getElementById('cursor');
        var ring = document.getElementById('cursor-ring');
        if (!cursor || !ring) return;

        var isCoarse = window.matchMedia('(pointer: coarse)').matches;
        var isHoverNone = window.matchMedia('(hover: none)').matches;
        if (isCoarse || isHoverNone) {
          cursor.style.display = 'none';
          ring.style.display = 'none';
          return;
        }

        var x = 0;
        var y = 0;
        var ringX = 0;
        var ringY = 0;
        var scale = 1;
        var ringScale = 1;
        var hoverScale = 1.6;
        var ringHoverScale = 1.2;
        var visible = false;

        document.documentElement.classList.add('cursor-ready');

        function show() {
          if (visible) return;
          visible = true;
          cursor.style.opacity = '1';
          ring.style.opacity = '1';
        }

        function onMove(e) {
          x = e.clientX;
          y = e.clientY;
          cursor.style.transform =
            'translate(' + (x - 8) + 'px,' + (y - 8) + 'px) scale(' + scale + ')';
          show();
        }

        function render() {
          ringX += (x - ringX) * 0.14;
          ringY += (y - ringY) * 0.14;
          ring.style.transform =
            'translate(' + (ringX - 20) + 'px,' + (ringY - 20) + 'px) scale(' + ringScale + ')';
          requestAnimationFrame(render);
        }

        function setHover(active) {
          scale = active ? hoverScale : 1;
          ringScale = active ? ringHoverScale : 1;
        }

        document.addEventListener('pointermove', onMove, { passive: true });
        document.addEventListener('mouseover', function (e) {
          var target = e.target;
          if (!(target instanceof Element)) return;
          if (target.closest('a, button, input, textarea, select, [role="button"], [data-cursor="pointer"]')) {
            setHover(true);
            return;
          }
          if (target.closest('[data-cursor-exclude]')) {
            setHover(false);
            return;
          }
          setHover(false);
        });

        render();
      })();
    </script>
    <Analytics />
  </body>
</html>
