---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<div class="not-prose my-8 grid gap-3 sm:grid-cols-2" role="list">
  {items.map((item, i) => (
    <div
      class="flex items-start gap-3 border-4 border-foreground bg-card p-4 shadow-[var(--shadow-sm)]"
      role="listitem"
    >
      <span class="shrink-0 w-8 h-8 flex items-center justify-center bg-foreground text-background text-sm font-black">
        {String(i + 1).padStart(2, '0')}
      </span>
      <span class="text-sm font-bold leading-snug pt-1">{item}</span>
    </div>
  ))}
</div>
