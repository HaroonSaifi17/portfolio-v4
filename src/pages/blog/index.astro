---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.svelte';
import Footer from '../../components/Footer.svelte';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout
  title="Engineering Blog | Mohd Haroon"
  description="Read Mohd Haroon's engineering blog on web development, TypeScript, Angular, deployment lessons, and modern developer tooling."
  image="/images/preview.png"
  imageAlt="Mohd Haroon engineering blog"
  keywords={[
    'engineering blog',
    'web development articles',
    'typescript blog',
    'angular blog',
  ]}
  breadcrumbs={[
    { name: 'Home', item: '/' },
    { name: 'Blog', item: '/blog' },
  ]}
>
  <Navbar client:load />

  <main class="max-w-7xl mx-auto px-6 py-20 space-y-16">
    <header class="space-y-4">
      <h1 class="page-title text-5xl md:text-7xl font-black uppercase tracking-tighter">
        Blog
      </h1>
      <p class="page-subtitle text-xl font-bold max-w-xl border-l-4 border-primary pl-6">
        Thoughts on web development, tooling, and the developer experience.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="listing-card group flex flex-col items-start border-4 border-foreground bg-card p-8 shadow-[var(--shadow-lg)] content-card"
            data-astro-prefetch
            transition:name={`blog-card-${post.id}`}
          >
            <span
              class="font-black uppercase tracking-widest bg-foreground text-background px-3 py-1 text-xs"
              transition:name={`blog-date-${post.id}`}
            >
              {formatDate(post.data.pubDate)}
            </span>
            <h2
              class="text-2xl md:text-3xl font-black uppercase tracking-tight mt-4 mb-3"
              transition:name={`blog-title-${post.id}`}
            >
              {post.data.title}
            </h2>
            <p class="text-lg font-medium text-muted-foreground leading-relaxed mb-6 text-justify-fill">
              {post.data.description}
            </p>
            <span class="inline-block mt-auto border-b-4 border-foreground text-lg font-black uppercase">
              Read Post &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </main>

  <Footer />
</Layout>
