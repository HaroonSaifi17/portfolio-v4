---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.svelte';
import Hero from '../components/Hero.svelte';
import Marquee from '../components/Marquee.svelte';
import ProjectCard from '../components/ProjectCard.svelte';
import Experience from '../components/Experience.svelte';
import Footer from '../components/Footer.svelte';
import { getCollection } from 'astro:content';

const techStack = [
  'TypeScript',
  'React',
  'Next.js',
  'Angular',
  'Astro',
  'Node.js',
  'tRPC',
  'Rust',
  'Solidity',
  'Web3',
];

const projects = [
  {
    title: 'MeowFi DApp',
    tech: 'React / Node.js / tRPC / Web3',
    description:
      'Full-stack DeFi application featuring Liquidity Pools, Bribe Vaults, and token swaps via Balancer V3 protocols. Built with end-to-end type safety across the entire stack.',
    href: '/case-studies/meowfi-dapp',
  },
  {
    title: 'PrepZone',
    tech: 'Angular / Node.js / Express / MongoDB',
    description:
      'EdTech assessment platform featuring secure Google OAuth, managing a repository of 700+ questions for adaptive mock tests and real-time performance analytics.',
    href: '/case-studies/prepzone-platform',
  },
  {
    title: 'ReqQuest',
    tech: 'Analog.js / tRPC / Supabase',
    description:
      'Robust browser-based API client serving as a lightweight Postman alternative. Reduced runtime integration errors by 30% with end-to-end type safety.',
    href: 'https://reqquest-ten.vercel.app',
  },
  {
    title: 'Sorting Visualizer',
    tech: 'Vanilla JavaScript / CSS3',
    description:
      'Interactive visualization tool demonstrating sorting algorithms in real-time with adjustable speed and array size controls.',
    href: 'https://sorting-visualizer-sandy-eight.vercel.app',
  },
];

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout>
  <Navbar client:load />

  <main class="space-y-12 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 py-20 space-y-32">
      <Hero client:load />
    </div>

    <Marquee items={techStack} />

    <div class="max-w-7xl mx-auto px-6 pt-8 pb-20 space-y-32">
    <section id="work" class="space-y-12 border-t-4 border-foreground pt-12">
      <h2
        class="section-heading text-5xl md:text-7xl font-black uppercase tracking-tighter"
      >
        Selected Work
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        {
          projects.map((project, i) => (
              <ProjectCard
                title={project.title}
                tech={project.tech}
                description={project.description}
                href={project.href}
                index={i + 1}
              />
            ))
        }
      </div>
    </section>

    <Experience client:visible />

    <!-- Blog Section -->
    <section class="space-y-12 border-t-4 border-foreground pt-20">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <h2
          class="section-heading text-5xl md:text-7xl font-black uppercase tracking-tighter"
        >
          Blog
        </h2>
        <a
          href="/blog"
          class="section-heading inline-block border-b-4 border-foreground text-xl font-black uppercase nav-link-hover"
          data-astro-prefetch
        >
          All Posts &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          recentPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="blog-card group block border-4 border-foreground bg-card p-6 shadow-[var(--shadow-lg)] content-card"
              data-astro-prefetch
              transition:name={`blog-card-${post.id}`}
            >
              <span
                class="font-black uppercase tracking-widest bg-foreground text-background px-2 py-1 text-xs"
                transition:name={`blog-date-${post.id}`}
              >
                {formatDate(post.data.pubDate)}
              </span>
              <h3
                class="text-xl font-black uppercase tracking-tight mt-4 mb-2"
                transition:name={`blog-title-${post.id}`}
              >
                {post.data.title}
              </h3>
              <p class="text-base font-medium text-muted-foreground leading-relaxed line-clamp-3">
                {post.data.description}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    </div>
  </main>

  <Footer client:visible animate />
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.set('.marquee-wrapper', { autoAlpha: 0, y: 20 });
  gsap.set('.section-heading', { autoAlpha: 0, y: 50 });
  gsap.set('.project-card', { autoAlpha: 0, y: 80 });
  gsap.set('.card-index', { autoAlpha: 0, scale: 0 });
  gsap.set('.blog-card', { autoAlpha: 0, y: 60 });

  // Marquee fade-in on scroll
  gsap.to('.marquee-wrapper', {
    autoAlpha: 1,
    y: 0,
    duration: 0.6,
    ease: 'power4.out',
    scrollTrigger: {
      trigger: '.marquee-wrapper',
      start: 'top 90%',
      once: true,
    },
  });

  // Section headings reveal
  gsap.utils.toArray<HTMLElement>('.section-heading').forEach((el) => {
    gsap.to(el, {
      y: 0,
      autoAlpha: 1,
      duration: 0.7,
      ease: 'power4.out',
      scrollTrigger: {
        trigger: el,
        start: 'top 88%',
        once: true,
      },
    });
  });

  // Project cards — staggered scroll-triggered entrance
  ScrollTrigger.batch('.project-card', {
    onEnter: (batch) =>
      gsap.to(batch, {
        y: 0,
        autoAlpha: 1,
        duration: 0.6,
        ease: 'power4.out',
        stagger: 0.15,
        clearProps: 'transform,opacity,visibility',
      }),
    start: 'top 88%',
    once: true,
  });

  // Card index circles pop in after cards
  ScrollTrigger.batch('.card-index', {
    onEnter: (batch) =>
      gsap.to(batch, {
        scale: 1,
        autoAlpha: 1,
        duration: 0.4,
        ease: 'back.out(2)',
        stagger: 0.1,
        delay: 0.3,
        clearProps: 'transform,opacity,visibility',
      }),
    start: 'top 88%',
    once: true,
  });

  // Blog cards — staggered entrance
  ScrollTrigger.batch('.blog-card', {
    onEnter: (batch) =>
      gsap.to(batch, {
        y: 0,
        autoAlpha: 1,
        duration: 0.5,
        ease: 'power4.out',
        stagger: 0.1,
        clearProps: 'transform,opacity,visibility',
      }),
    start: 'top 88%',
    once: true,
  });

</script>
