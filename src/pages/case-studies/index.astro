---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.svelte';
import Footer from '../../components/Footer.svelte';
import { getCollection } from 'astro:content';

const studies = (await getCollection('case-studies')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout title="Case Studies — Mohd Haroon" description="Deep dives into projects, decisions, and lessons learned.">
  <Navbar client:load />

  <main class="max-w-7xl mx-auto px-6 py-20 space-y-16">
    <header class="space-y-4">
      <h1 class="page-title text-5xl md:text-7xl font-black uppercase tracking-tighter">
        Case Studies
      </h1>
      <p class="page-subtitle text-xl font-bold max-w-xl border-l-4 border-primary pl-6">
        Deep dives into projects, decisions, and lessons learned.
      </p>
    </header>

    <div class="grid grid-cols-1 gap-6">
      {
        studies.map((study, i) => (
          <a
            href={`/case-studies/${study.id}`}
            class="group block border-4 border-foreground bg-card content-card"
            data-astro-prefetch
            transition:name={`case-study-card-${study.id}`}
          >
            <div class="flex flex-col md:flex-row">
              {/* Left: Number + Category */}
              <div class="flex md:flex-col items-center justify-center gap-3 md:gap-2 px-6 py-4 md:py-8 md:px-8 border-b-4 md:border-b-0 md:border-r-4 border-foreground bg-foreground text-background md:min-w-[7rem]">
                <span class="text-3xl md:text-5xl font-black leading-none">
                  {String(i + 1).padStart(2, '0')}
                </span>
                {study.data.category && (
                  <span class="text-[0.6rem] font-black uppercase tracking-widest text-center opacity-70">
                    {study.data.category}
                  </span>
                )}
              </div>

              {/* Right: Content */}
              <div class="flex-1 p-6 md:p-8 flex flex-col gap-3">
                <div class="flex flex-wrap items-center gap-3">
                  <span
                    class="font-black uppercase tracking-widest bg-foreground text-background px-3 py-1 text-xs"
                    transition:name={`case-study-date-${study.id}`}
                  >
                    {formatDate(study.data.pubDate)}
                  </span>
                  {study.data.role && (
                    <span class="font-bold uppercase tracking-wider text-muted-foreground text-xs">
                      {study.data.role}
                    </span>
                  )}
                </div>

                <h2
                  class="text-2xl md:text-4xl font-black uppercase tracking-tight leading-tight"
                  transition:name={`case-study-title-${study.id}`}
                >
                  {study.data.title}
                </h2>

                <p class="text-lg font-medium text-muted-foreground leading-relaxed max-w-2xl">
                  {study.data.description}
                </p>

                {study.data.stack && study.data.stack.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-1">
                    {study.data.stack.slice(0, 6).map((tech) => (
                      <span class="text-[0.65rem] font-black uppercase tracking-wider px-2 py-0.5 border-2 border-foreground bg-secondary">
                        {tech}
                      </span>
                    ))}
                    {study.data.stack.length > 6 && (
                      <span class="text-[0.65rem] font-black uppercase tracking-wider px-2 py-0.5 text-muted-foreground">
                        +{study.data.stack.length - 6}
                      </span>
                    )}
                  </div>
                )}

                <span class="inline-block mt-2 border-b-4 border-foreground text-lg font-black uppercase group-hover:border-primary transition-colors">
                  Read Study &rarr;
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </main>

  <Footer />
</Layout>
